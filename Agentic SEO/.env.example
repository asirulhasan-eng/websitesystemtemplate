# =============================================================================
# {{SITE_NAME}} Agent — Master .env
# =============================================================================
# Copy this file to .env and fill in every value.
# The agent's env.js searches for `.env` in the CWD then in the agent root
# (/opt/client-agent), so this single file is the one source of truth for
# all runtime credentials and config.
#
# HOW VALUES ARE SET:
#   - Lines with {{PLACEHOLDER}} tokens are filled by setup/customize.ps1
#     using values from site.config.json. Do not edit those tokens by hand.
#   - Blank values (KEY=) must be filled in manually after provisioning.
#   - Values with defaults are pre-filled; change them only if needed.
# =============================================================================


# -----------------------------------------------------------------------------
# SECTION 1 — SITE IDENTITY
# Filled automatically by customize.ps1 from site.config.json.
# You can also set them manually if not using the provisioner.
# -----------------------------------------------------------------------------
DOMAIN={{DOMAIN}}
SITE_NAME={{SITE_NAME}}
SITE_DESCRIPTION={{SITE_DESCRIPTION}}
OWNER_NAME={{OWNER_NAME}}
NICHE={{NICHE}}
AUDIENCE={{AUDIENCE}}
ADMIN_EMAIL={{ADMIN_EMAIL}}
TIMEZONE={{TIMEZONE}}
TIMEZONE_ABBR={{TIMEZONE_ABBR}}


# -----------------------------------------------------------------------------
# SECTION 2 — SERVER / SSH ACCESS
# Used by connection/connect-ssh.bat and connection/connect-putty.bat.
# Note: the .bat files currently hardcode these values. Update them manually
# when your server IP or user changes.
# -----------------------------------------------------------------------------
SERVER_HOST=89.167.16.167
SERVER_USER=root
# Paths are relative to the connection/ folder in those .bat files.
# SSH_KEY_PATH and PPK_KEY_PATH are resolved locally by the .bat files;
# no env var injection yet — update the .bat files directly.


# -----------------------------------------------------------------------------
# SECTION 3 — GITHUB
# Used by: cli/lib/env.js, cli/commands (PR creation, pushes)
# -----------------------------------------------------------------------------
GITHUB_TOKEN=
# GITHUB_TOKEN format: github_pat_...

GITHUB_PR_BASE=main


# -----------------------------------------------------------------------------
# SECTION 4 — CLOUDFLARE PAGES
# Used by: cli/lib/cloudflare.js
# -----------------------------------------------------------------------------
CLOUDFLARE_ACCOUNT_ID=
# CLOUDFLARE_ACCOUNT_ID format: 32-character hex string

CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_API_TOKEN format: cfut_...

CLOUDFLARE_PROJECT_NAME={{CLOUDFLARE_PROJECT}}
CLOUDFLARE_PRODUCTION_BRANCH=main


# -----------------------------------------------------------------------------
# SECTION 5 — GOOGLE SEARCH CONSOLE (OAuth2)
# Used by: cli/lib/gsc.js
# Get these from the Google Cloud Console OAuth2 credentials page.
# -----------------------------------------------------------------------------
GSC_SITE_URL=sc-domain:{{DOMAIN}}

GSC_CLIENT_ID=
# GSC_CLIENT_ID format: xxxxxxxxxx-xxx.apps.googleusercontent.com

GSC_CLIENT_SECRET=
# GSC_CLIENT_SECRET format: GOCSPX-...

GSC_REFRESH_TOKEN=
# GSC_REFRESH_TOKEN format: 1//...
# Run the OAuth consent flow once to get this.

# GSC_ACCESS_TOKEN is optional — the agent refreshes it automatically
# from the refresh token above. Only set it if you want to pre-seed.
# GSC_ACCESS_TOKEN=ya29....


# -----------------------------------------------------------------------------
# SECTION 6 — SERP / SEO DATA APIS
# Used by: cli/lib/serper.js, cli/lib/dataforseo.js
# -----------------------------------------------------------------------------
SERPER_API_KEY=
# Get from: https://serper.dev/dashboard

DATAFORSEO_LOGIN=
# DataForSEO account email

DATAFORSEO_PASSWORD=
# DataForSEO account password

RAPIDAPI_KEY=
# RapidAPI key — used by tools/youtube-transcript.ps1
# Get from: https://rapidapi.com/dashboard → Your Apps → Authorization
# The specific API used: youtube-captions-transcript-subtitles-video-combiner


# -----------------------------------------------------------------------------
# SECTION 6b — ANALYTICS & TRACKING IDs
# Used by: setup/inject-skills.ps1 (Layer 2 structural injection into skill files)
# These are read from website-profile.json (generated by analyze-website.ps1),
# but you can also set them here for manual reference.
# -----------------------------------------------------------------------------
GA4_MEASUREMENT_ID=
# Google Analytics 4 Measurement ID, e.g. G-XXXXXXXXXX

CLARITY_ID=
# Microsoft Clarity project ID, e.g. ww29j18bkr


# -----------------------------------------------------------------------------
# SECTION 6c — SOCIAL MEDIA HANDLES
# Used by: setup/inject-skills.ps1 (Layer 2 structural injection into skill files)
# -----------------------------------------------------------------------------
TWITTER_HANDLE=
# e.g. @youragency

FACEBOOK_PAGE=
# e.g. youragency (just the page slug, no URL)

YOUTUBE_HANDLE=
# e.g. YourAgency (just the handle, no @)



# -----------------------------------------------------------------------------
# SECTION 7 — EMAIL — SMTP (OUTBOUND)
# Used by: cli/lib/email_credentials.js → smtp.js
# For Gmail: enable 2FA and create an App Password (16 chars, spaces stripped).
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
# true = STARTTLS on port 587 | ssl = TLS-on-connect on port 465

SMTP_USER=
# Full Gmail address, e.g. you@gmail.com

SMTP_PASS=
# Gmail App Password (16-char token, spaces are stripped automatically)

EMAIL_FROM=
# Defaults to SMTP_USER if left blank

EMAIL_FROM_NAME={{SITE_NAME}} Agent

EMAIL_TO=
# Default recipient for general agent notifications


# -----------------------------------------------------------------------------
# SECTION 8 — EMAIL — APPROVAL & ALERTS (IMAP + ROUTING)
# Used by: cli/lib/email_credentials.js → imap.js, followups.js
# For Gmail the IMAP credentials are usually the same as SMTP.
# -----------------------------------------------------------------------------
IMAP_HOST=imap.gmail.com
IMAP_PORT=993

IMAP_USER=
# Defaults to SMTP_USER if left blank

IMAP_PASS=
# Defaults to SMTP_PASS if left blank

APPROVAL_EMAIL_TO=
# Address that receives opt-out approval emails from the agent

ALERT_EMAIL_TO=
# Address that receives system health alerts

APPROVAL_ALLOWED_SENDERS=
# Comma-separated list of email addresses trusted for approval replies
# e.g. owner@example.com,manager@example.com

APPROVAL_THREAD_IDS=
# (Optional) Pre-seeded email thread IDs for the approval flow


# -----------------------------------------------------------------------------
# SECTION 9 — AGENT RUNTIME CONFIG
# Used by: cli/lib/git.js, cli/lib/env.js, cron scripts
# -----------------------------------------------------------------------------
SEO_AGENT_GIT_NAME={{SITE_NAME}} Agent
SEO_AGENT_GIT_EMAIL=agent@{{DOMAIN}}
SEO_AGENT_TIMEZONE={{TIMEZONE}}

# Optional: override the path to this .env file
# SEO_AGENT_ENV_FILE=/custom/path/to/.env

# Optional: override the agent root path detection
# CLIENT_AGENT_ROOT=/opt/client-agent


# -----------------------------------------------------------------------------
# SECTION 10 — SERVER PATHS
# Used by: hermes/deploy-hermes.sh, cli/lib/site_paths.js, config/site.json
# Change these only if you deviate from the default /opt/client-* layout.
# -----------------------------------------------------------------------------
CLIENT_SITE_ROOT=/opt/client-site
CLIENT_OBSIDIAN_ROOT=/opt/client-obsidian
CLIENT_BACKUP_REPOS=/opt/client-sqlite,/opt/client-obsidian,/opt/client-agent


# -----------------------------------------------------------------------------
# SECTION 11 — SOCIAL MEDIA POSTING
# Used by: cli/commands/social-post.js, social-send.js, social-status.js
# The webhook fans out to Facebook / Instagram / Pinterest / X (e.g. Make.com).
# -----------------------------------------------------------------------------
SOCIAL_WEBHOOK_URL=
# Webhook endpoint that receives the post payload. Required for `social send`.

SOCIAL_DEFAULT_CHANNELS=facebook,instagram,pinterest,linkedin,x
# Channels enabled by default (x = twitter). Add/remove freely, e.g. add reddit.

# Posting cadence per platform (which post once per infographic vs once per blog).
# Leave blank to use defaults below. A spec's `cadence` map overrides these.
#   each = one post per infographic   ·   once = one post per blog (first batch)
# Defaults: facebook/instagram/pinterest = each; linkedin/twitter/reddit/youtube = once.
SOCIAL_PER_INFOGRAPHIC=facebook,instagram,pinterest
SOCIAL_PER_BLOG=linkedin,twitter,reddit

SOCIAL_MIN_INTERVAL_MINUTES=60
# Per-platform floor: a platform never posts more often than this.

SOCIAL_PICKUP_INTERVAL_MINUTES=90
# Cron pickup cadence base: minutes between draining successive batches.

SOCIAL_PICKUP_JITTER_MINUTES=11
# Random +/- jitter applied to the pickup cadence (organic spacing).

SOCIAL_PAYLOAD_ARRAY=false
# true → wrap the webhook body as [ {…} ]. Default sends a single {…} object.

# Identity fields injected into the webhook payload (leave blank if unused):
SOCIAL_WEBSITE_URL=https://{{DOMAIN}}/
SOCIAL_FACEBOOK_PAGE=
SOCIAL_FACEBOOK_PROFILE_URL=
SOCIAL_INSTAGRAM_PAGE=
SOCIAL_INSTAGRAM_PROFILE_URL=
SOCIAL_PINTEREST_BOARD=
SOCIAL_PINTEREST_BOARD_URL=
SOCIAL_PINTEREST_PROFILE_URL=
SOCIAL_LINKEDIN_COMPANY=
SOCIAL_LINKEDIN_PROFILE_URL=
SOCIAL_TWITTER_PROFILE_URL=
SOCIAL_REDDIT_PROFILE_URL=
SOCIAL_REDDIT_SUBREDDIT=
# Subreddit display name for Reddit posts (e.g. r/smallbusiness → smallbusiness)


# =============================================================================
# HERMES AGENT SECRETS  (live in ~/.hermes/.env on the server — NOT here)
# =============================================================================
# The following are set in ~/.hermes/.env (a separate file Hermes reads):
#
#   OPENROUTER_API_KEY=sk-or-...    # or whichever provider key Hermes needs
#   TELEGRAM_BOT_TOKEN=...          # for the Hermes Gateway (optional)
#
# See hermes/config/config.yaml for model/provider config.
# deploy-hermes.sh (Step 14) secures that file with chmod 600.
# =============================================================================
